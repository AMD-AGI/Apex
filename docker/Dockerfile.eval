# Dockerfile.eval — Full evaluation pipeline container
#
# Contains: keystone-internal, MCPs, Magpie, Claude Code SDK, graders
# GPU: Required (ROCm devices mounted via --device)
#
# Build:
#   docker build -f docker/Dockerfile.eval -t keystone-eval .
#
# Run:
#   docker run --rm \
#     --device=/dev/kfd --device=/dev/dri --group-add video \
#     -v $(pwd)/output:/workspace/output \
#     -v ~/.cache/huggingface:/root/.cache/huggingface \
#     -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY \
#     keystone-eval \
#     python pipeline.py --model deepseek-ai/DeepSeek-R1 --kernel fused_moe

FROM rocm/pytorch:rocm6.3_ubuntu22.04_py3.10_pytorch_release_2.4.0

WORKDIR /workspace

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq && \
    rm -rf /var/lib/apt/lists/*

# Python deps
COPY setup.sh /workspace/setup.sh
RUN pip install --no-cache-dir \
    pyyaml requests chromadb sentence-transformers \
    boto3 claude-agent-sdk

# Copy project
COPY . /workspace/

# Install MCPs and Magpie (editable)
RUN bash tools/setup_tools.sh --claude 2>/dev/null || true

# Install keystone-internal graders as importable
ENV PYTHONPATH="/workspace:/workspace/graders:/workspace/prompts:${PYTHONPATH}"

ENTRYPOINT ["python"]
CMD ["pipeline.py", "--help"]
