# Dockerfile.grader — Grader container with Magpie
#
# Runs kernel_grader or model_grader against output/ directory.
# GPU required for Magpie compare/benchmark.
#
# Build:
#   docker build -f docker/Dockerfile.grader -t keystone-grader .
#
# Run:
#   docker run --rm \
#     --device=/dev/kfd --device=/dev/dri --group-add video \
#     -v $(pwd)/output:/workspace/output \
#     keystone-grader \
#     python -m kernel_grader --json

FROM rocm/pytorch:rocm6.3_ubuntu22.04_py3.10_pytorch_release_2.4.0

WORKDIR /workspace

RUN pip install --no-cache-dir pyyaml requests

# Copy graders and Magpie
COPY graders/ /workspace/graders/
COPY prompts/ /workspace/prompts/
COPY tools/magpie/ /workspace/tools/magpie/

# Install Magpie
RUN if [ -d /workspace/tools/magpie/Magpie ]; then \
      pip install --no-cache-dir -e "/workspace/tools/magpie/Magpie[mcp]" 2>/dev/null || true; \
    fi

ENV PYTHONPATH="/workspace:/workspace/graders:/workspace/prompts:${PYTHONPATH}"

ENTRYPOINT ["python"]
CMD ["-m", "kernel_grader", "--help"]
