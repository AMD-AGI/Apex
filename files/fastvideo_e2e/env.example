export APEX_ROOT=${APEX_ROOT:-/path/to/Apex}
export APEX_VENV_ACTIVATE=${APEX_VENV_ACTIVATE:-$APEX_ROOT/.venv/bin/activate}

export FASTVIDEO_REPO=${FASTVIDEO_REPO:-/path/to/FastVideo}
export FASTVIDEO_BASELINE_REPO=${FASTVIDEO_BASELINE_REPO:-/path/to/FastVideo_baseline}

export FASTVIDEO_COMPARE_SCRIPT=${FASTVIDEO_COMPARE_SCRIPT:-$APEX_ROOT/files/fastvideo_e2e/compare_e2e.py}
export FASTVIDEO_PROFILE_SCRIPT=${FASTVIDEO_PROFILE_SCRIPT:-$APEX_ROOT/files/fastvideo_e2e/profile_e2e.py}

export FASTVIDEO_MODEL_NAME=${FASTVIDEO_MODEL_NAME:-FastVideo/FastWan2.1-T2V-1.3B-Diffusers}
export FASTVIDEO_PROFILER_CSV=${FASTVIDEO_PROFILER_CSV:-/tmp/rocprof_fastvideo_kernel_stats.csv}
export FASTVIDEO_BASELINE_RESULT_JSON=${FASTVIDEO_BASELINE_RESULT_JSON:-/tmp/fastvideo_baseline.json}
export FASTVIDEO_OPTIMIZED_RESULT_JSON=${FASTVIDEO_OPTIMIZED_RESULT_JSON:-/tmp/fastvideo_optimized.json}
export FASTVIDEO_E2E_OUTPUT_DIR=${FASTVIDEO_E2E_OUTPUT_DIR:-/tmp/fastvideo_e2e_outputs}
